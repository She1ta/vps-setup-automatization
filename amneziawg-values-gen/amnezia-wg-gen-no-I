<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AmneziaWG 2.0 Parameter Generator</title>
    <style>
        :root {
            --bg-main: #0f172a;
            --bg-card: #1e293b;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --accent: #10b981;
            --accent-hover: #059669;
            --border: #334155;
        }
        * { box-sizing: border-box; }
        body { 
            font-family: system-ui, -apple-system, sans-serif; 
            background: var(--bg-main); 
            color: var(--text-main); 
            padding: 2rem; 
            max-width: 1000px; 
            margin: auto; 
            line-height: 1.5;
        }
        h1 { margin-top: 0; font-size: 1.75rem; color: var(--accent); }
        h3 { margin-top: 0; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; font-size: 1.1rem; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start; }
        @media(max-width: 768px) { .grid { grid-template-columns: 1fr; } }
        .card { background: var(--bg-card); padding: 1.5rem; border-radius: 0.75rem; border: 1px solid var(--border); margin-bottom: 1.5rem; }
        .row { display: flex; gap: 1rem; margin-bottom: 1rem; }
        .col { flex: 1; }
        label { display: block; margin-bottom: 0.25rem; font-size: 0.85rem; color: var(--text-muted); font-weight: 600; }
        input { 
            width: 100%; padding: 0.5rem; border-radius: 0.35rem; 
            border: 1px solid var(--border); background: var(--bg-main); 
            color: var(--text-main); font-family: monospace; font-size: 1rem;
        }
        input:focus { outline: 2px solid var(--accent); border-color: transparent; }
        button { 
            cursor: pointer; padding: 0.6rem 1.2rem; background: var(--accent); 
            color: white; border: none; border-radius: 0.35rem; font-weight: 600; 
            transition: 0.2s; font-size: 0.9rem;
        }
        button:hover { background: var(--accent-hover); }
        .btn-outline { background: transparent; border: 1px solid var(--accent); color: var(--accent); width: 100%; margin-top: 0.5rem; }
        .btn-outline:hover { background: var(--accent); color: white; }
        .btn-large { width: 100%; font-size: 1.1rem; padding: 1rem; margin-bottom: 1.5rem; }
        textarea { 
            width: 100%; height: 320px; padding: 1rem; border-radius: 0.35rem; 
            border: 1px solid var(--border); background: #020617; color: var(--accent); 
            font-family: monospace; font-size: 1.1rem; resize: vertical; 
        }
        .help-text { font-size: 0.8rem; color: var(--text-muted); margin-top: -0.5rem; margin-bottom: 1rem; display: block; }
    </style>
</head>
<body>

    <h1>AmneziaWG 2.0 Parameter Generator</h1>
    <p style="color: var(--text-muted); margin-bottom: 2rem;">Offline interactive generator based on the official amneziawg-install.sh logic. Adjust values manually or randomly generate them.</p>

    <div class="grid">
        <!-- LEFT COLUMN: CONTROLS -->
        <div>
            <button class="btn-large" onclick="generateAll()">🔄 Randomize All Values</button>

            <div class="card">
                <h3>Junk Packet Settings (Jc, Jmin, Jmax)</h3>
                <span class="help-text">Controls the addition of junk data to bypass DPI packet size analysis.</span>
                <div class="row">
                    <div class="col">
                        <label>Jc (3 - 10)</label>
                        <input type="number" id="jc" min="1" max="128">
                    </div>
                    <div class="col">
                        <label>Jmin (1 - 1280)</label>
                        <input type="number" id="jmin" min="1" max="1280">
                    </div>
                    <div class="col">
                        <label>Jmax (1 - 1280)</label>
                        <input type="number" id="jmax" min="1" max="1280">
                    </div>
                </div>
                <button class="btn-outline" onclick="genJ()">Randomize Junk Packets</button>
            </div>

            <div class="card">
                <h3>Obfuscation Offsets (S1 - S4)</h3>
                <span class="help-text">Modifies packet structure. Values must avoid the 56-byte WireGuard handshake offset.</span>
                <div class="row">
                    <div class="col">
                        <label>S1</label>
                        <input type="number" id="s1" min="15" max="150">
                    </div>
                    <div class="col">
                        <label>S2</label>
                        <input type="number" id="s2" min="15" max="150">
                    </div>
                </div>
                <button class="btn-outline" onclick="genS1S2()" style="margin-bottom: 1rem;">Randomize S1 & S2</button>
                
                <div class="row">
                    <div class="col">
                        <label>S3</label>
                        <input type="number" id="s3" min="15" max="150">
                    </div>
                    <div class="col">
                        <label>S4</label>
                        <input type="number" id="s4" min="15" max="150">
                    </div>
                </div>
                <button class="btn-outline" onclick="genS3S4()">Randomize S3 & S4</button>
            </div>

            <div class="card">
                <h3>Ranged Headers (H1 - H4)</h3>
                <span class="help-text">Non-overlapping ranges to randomize packet header magic values.</span>
                <div class="row">
                    <div class="col">
                        <label>H1</label>
                        <input type="text" id="h1">
                    </div>
                    <div class="col">
                        <label>H2</label>
                        <input type="text" id="h2">
                    </div>
                </div>
                <div class="row">
                    <div class="col">
                        <label>H3</label>
                        <input type="text" id="h3">
                    </div>
                    <div class="col">
                        <label>H4</label>
                        <input type="text" id="h4">
                    </div>
                </div>
                <button class="btn-outline" onclick="genH1H4()">Randomize Ranged Headers</button>
            </div>
        </div>

        <!-- RIGHT COLUMN: OUTPUT -->
        <div style="position: sticky; top: 2rem;">
            <div class="card">
                <h3>Generated Configuration</h3>
                <p class="help-text">Copy and paste these lines into the <code>[Interface]</code> block of your AmneziaWG server config (and client configs).</p>
                <textarea id="output" readonly></textarea>
                <button style="width: 100%; margin-top: 1rem;" onclick="copyOutput()">📋 Copy to Clipboard</button>
            </div>
        </div>
    </div>

    <script>
        // Attach event listeners so typing in the inputs updates the text box live
        document.addEventListener('DOMContentLoaded', () => {
            generateAll();
            const inputs = document.querySelectorAll('input');
            inputs.forEach(input => input.addEventListener('input', updateOutput));
        });

        // Safe integer randomizer
        function getRandomInt(min, max) {
            return Math.floor(Math.random() * (max - min + 1)) + min;
        }

        // J parameters
        function genJ() {
            document.getElementById('jc').value = getRandomInt(3, 10);
            document.getElementById('jmin').value = 50;
            document.getElementById('jmax').value = 1000;
            updateOutput();
        }

        // S1 and S2 parameters (must avoid +56 offset)
        function genS1S2() {
            let s1, s2;
            do {
                s1 = getRandomInt(15, 150);
                s2 = getRandomInt(15, 150);
            } while (s1 + 56 === s2 || s2 + 56 === s1);
            document.getElementById('s1').value = s1;
            document.getElementById('s2').value = s2;
            updateOutput();
        }

        // S3 and S4 parameters (must avoid +56 offset)
        function genS3S4() {
            let s3, s4;
            do {
                s3 = getRandomInt(15, 150);
                s4 = getRandomInt(15, 150);
            } while (s3 + 56 === s4 || s4 + 56 === s3);
            document.getElementById('s3').value = s3;
            document.getElementById('s4').value = s4;
            updateOutput();
        }

        // H1 to H4 Ranges (creates 4 strictly non-overlapping ranges)
        function genH1H4() {
            const RANGE_SIZE = 100000000;
            const MIN_VAL = 5;
            const MAX_VAL = 2147483647;
            const GAP = 1;

            let RAW_AVAILABLE = MAX_VAL - MIN_VAL - GAP * 3;
            let AVAILABLE_RANGE = RAW_AVAILABLE - (RAW_AVAILABLE % 4);
            let SEGMENT_SIZE = Math.floor(AVAILABLE_RANGE / 4);

            let RANDOM_OFFSET_MAX = SEGMENT_SIZE - RANGE_SIZE;

            // H1
            let h1_start = MIN_VAL + getRandomInt(0, RANDOM_OFFSET_MAX);
            let h1_max = h1_start + RANGE_SIZE - 1;

            // H2
            let h2_start = MIN_VAL + SEGMENT_SIZE + GAP + getRandomInt(0, RANDOM_OFFSET_MAX);
            let h2_max = h2_start + RANGE_SIZE - 1;

            // H3
            let h3_start = MIN_VAL + (SEGMENT_SIZE + GAP) * 2 + getRandomInt(0, RANDOM_OFFSET_MAX);
            let h3_max = h3_start + RANGE_SIZE - 1;

            // H4
            let h4_segment_start = MIN_VAL + (SEGMENT_SIZE + GAP) * 3;
            let h4_segment_max_start = MAX_VAL - RANGE_SIZE + 1;
            if (h4_segment_start > h4_segment_max_start) {
                h4_segment_start = h4_segment_max_start;
            }
            let h4_random_offset_max = MAX_VAL - h4_segment_start - RANGE_SIZE + 1;
            if (h4_random_offset_max < 0) h4_random_offset_max = 0;
            
            let h4_start = h4_segment_start + getRandomInt(0, h4_random_offset_max);
            let h4_max = h4_start + RANGE_SIZE - 1;

            document.getElementById('h1').value = `${h1_start}-${h1_max}`;
            document.getElementById('h2').value = `${h2_start}-${h2_max}`;
            document.getElementById('h3').value = `${h3_start}-${h3_max}`;
            document.getElementById('h4').value = `${h4_start}-${h4_max}`;
            
            updateOutput();
        }

        // Trigger all randomizers
        function generateAll() {
            genJ();
            genS1S2();
            genS3S4();
            genH1H4();
        }

        // Gather variables and update the text area
        function updateOutput() {
            const fields =['jc', 'jmin', 'jmax', 's1', 's2', 's3', 's4', 'h1', 'h2', 'h3', 'h4'];
            let out = '';
            fields.forEach(f => {
                const val = document.getElementById(f).value;
                const name = f.charAt(0).toUpperCase() + f.slice(1);
                out += `${name} = ${val}\n`;
            });
            document.getElementById('output').value = out;
        }

        // Copy button logic
        function copyOutput() {
            const out = document.getElementById('output');
            out.select();
            document.execCommand('copy');
            
            // Temporary visual feedback
            const btn = event.target;
            const originalText = btn.innerText;
            btn.innerText = "✅ Copied!";
            btn.style.background = "#059669";
            setTimeout(() => {
                btn.innerText = originalText;
                btn.style.background = "var(--accent)";
            }, 1500);
        }
    </script>
</body>
</html>
